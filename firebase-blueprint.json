{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "mobile": { "type": "string" },
        "role": { "type": "string" },
        "status": { "type": "string" },
        "joinedAt": { "type": "string" },
        "pincode": { "type": "string" },
        "address": { "type": "string" },
        "state": { "type": "string" },
        "district": { "type": "string" },
        "subDistrict": { "type": "string" },
        "village": { "type": "string" },
        "avatarColor": { "type": "string" },
        "department": { "type": "string" },
        "assignedAdminId": { "type": "string" }
      },
      "required": ["id", "name", "role", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    }
  }
}
